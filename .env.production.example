# =============================================================================
# Hireoven - Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# Primary database (app + auth.users / sessions when using lib/postgres/auth-bootstrap.sql)
DATABASE_URL=postgres://...
# Alias supported by lib/postgres/server.ts
# TARGET_POSTGRES_URL=postgres://...

# Cookie session signing (required in production). Generate: openssl rand -hex 32
AUTH_SESSION_SECRET=replace-with-64-char-hex

# Google sign-in (optional). Create OAuth client (Web) in Google Cloud Console.
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/google/callback
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Optional: local scripts that still use Supabase service role against a hosted project
# SUPABASE_SERVICE_ROLE_KEY=...
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# Direct Postgres connection string from Supabase (for dump/export only)
# SUPABASE_DB_URL=postgres://...

# Resume files — MinIO (official `minio` JS client; local Docker / Coolify service)
# Same object keys as before: resumes/{userId}/... — copy objects from old storage before cutover, or re-upload.
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_BUCKET=hireoven-resumes
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# Docker parity: MINIO_ROOT_USER / MINIO_ROOT_PASSWORD work instead of ACCESS_KEY / SECRET_KEY
# MINIO_PATH_STYLE=false   # set explicitly if your gateway needs virtual-hosted style

# Anthropic Claude (job normalization + visa detection)
# Get from: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend (email alerts + digests)
# Get from: resend.com → API keys
RESEND_API_KEY=re_...
# The domain you've verified in Resend (e.g. hireoven.com)
RESEND_FROM_DOMAIN=hireoven.com
# Route platform/support emails through support.hireoven.com
MAIL_FROM_DOMAIN=support.hireoven.com
# Recently added jobs emails should come from hello@hireoven.com
RECENT_JOBS_FROM_EMAIL="Hireoven Jobs <hello@hireoven.com>"

# Web Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:admin@hireoven.com

# Security
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-at-least-32-chars
# Generate with: openssl rand -hex 16
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# App
NEXT_PUBLIC_APP_URL=https://hireoven.com
ADMIN_EMAIL=admin@hireoven.com

# Logo enrichment — logo.dev (primary brand-mark provider)
# Get from: logo.dev → Dashboard → API Keys
# Used server-side (scripts) and client-side (NEXT_PUBLIC_ prefix served to browser)
LOGO_DEV_TOKEN=
# NEXT_PUBLIC_LOGO_DEV_TOKEN=   # expose to browser if needed (same value)

# Optional: Sentry error monitoring
# Get from: sentry.io → your project → Settings → Client Keys (DSN)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# Crawler performance and enrichment
# CRAWLER_COMPANY_CONCURRENCY=4
# CRAWLER_FETCH_TIMEOUT_MS=12000
# CRAWLER_HTTP_MAX_ATTEMPTS=3
# CRAWLER_DOMAIN_CONCURRENCY=3
# CRAWLER_REQUEST_MIN_DELAY_MS=250
# CRAWLER_REQUEST_MAX_DELAY_MS=900
# CRAWLER_HTTP_RETRY_BASE_DELAY_MS=500
# CRAWLER_DESCRIPTION_FETCH_CONCURRENCY=4
# CRAWLER_MAX_DESCRIPTION_FETCHES_PER_COMPANY=500
# CRAWLER_COMPANY_MAX_ATTEMPTS=2
# CRAWLER_COMPANY_RETRY_BASE_DELAY_MS=1200
# CRAWLER_AI_ENRICHMENT_MODE=async  # async | sync | off
# CRAWLER_AI_ENRICHMENT_MIN_CONFIDENCE_SCORE=0.86
# CRAWLER_AI_ENRICHMENT_MIN_COMPLETENESS_SCORE=0.78
# CRAWLER_AI_ENRICHMENT_BATCH_SIZE=40
# CRAWLER_AI_ENRICHMENT_CONCURRENCY=4
# CRAWLER_AI_ENRICHMENT_MAX_ATTEMPTS=3
