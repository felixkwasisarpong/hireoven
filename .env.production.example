# =============================================================================
# Hireoven — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# Supabase
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic Claude (job normalization + visa detection)
# Get from: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Resend (email alerts + digests)
# Get from: resend.com → API keys
RESEND_API_KEY=re_...
# The domain you've verified in Resend (e.g. hireoven.com)
RESEND_FROM_DOMAIN=hireoven.com
# Route platform/support emails through support.hireoven.com
MAIL_FROM_DOMAIN=support.hireoven.com
# Recently added jobs emails should come from hello@hireoven.com
RECENT_JOBS_FROM_EMAIL="Hireoven Jobs <hello@hireoven.com>"

# Web Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:admin@hireoven.com

# Security
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-at-least-32-chars
# Generate with: openssl rand -hex 16
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# App
NEXT_PUBLIC_APP_URL=https://hireoven.com
ADMIN_EMAIL=admin@hireoven.com

# Optional: Sentry error monitoring
# Get from: sentry.io → your project → Settings → Client Keys (DSN)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
